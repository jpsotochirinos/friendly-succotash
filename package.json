{
  "name": "tracker",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @tracker/db migrate",
    "db:validate:workflow-readiness": "pnpm --filter @tracker/db validate:workflow-readiness",
    "db:seed": "pnpm --filter @tracker/db seed",
    "docker:up": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml down",
    "docker:reset": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml down -v && pnpm docker:up",
    "setup": "bash scripts/setup-dev.sh",
    "verify:google-oauth": "bash scripts/verify-google-oauth-env.sh",
    "reset:pilot": "node scripts/reset-pilot.mjs",
    "db:seed:system-blueprints": "pnpm --filter @tracker/db seed:system-blueprints",
    "db:migrate:workflow-to-activities": "pnpm --filter @tracker/db migrate:data:workflow-to-activities",
    "test:brevo-email": "node --env-file=.env scripts/test-brevo-email.mjs"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.5.0"
  }
}
