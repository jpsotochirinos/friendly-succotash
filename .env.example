DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tracker_db
DATABASE_USER=tracker_user
DATABASE_PASSWORD=tracker_pass

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tracker-storage
MINIO_USE_SSL=false

JWT_SECRET=super-secret-jwt-key-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d
MAGIC_LINK_SECRET=super-secret-magic-link-key
MAGIC_LINK_EXPIRES_IN=15m

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OneDrive / SharePoint (Microsoft Graph) — importación por OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Usar "common" para cuentas personales y work/school
MICROSOFT_TENANT=common

# Límite de archivos por lote en workers Drive / Graph (evita abusos)
DRIVE_MAX_FILES_PER_BATCH=50000

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@tracker.local

APP_PORT=3000
APP_URL=http://localhost:3000
# Comma-separated if several frontends (SPA + otro host). En dev el API también permite 5174/5175 y 127.0.0.1 (Electron-Vite cuando 5173 está ocupado).
FRONTEND_URL=http://localhost:5173

# Worker: RSS ingest for legal feed (default hourly). Set FEED_INGEST_ENABLED=0 to disable.
# FEED_INGEST_CRON=0 * * * *
# FEED_INGEST_ENABLED=1
NODE_ENV=development

# Importación de clientes (TUS + lotes): firma de uploadToken; por defecto usa JWT_SECRET
IMPORT_UPLOAD_SECRET=

# OCR on-prem opcional (worker envía PDFs escaneados como JSON base64)
OCR_SERVICE_URL=

SCRAPING_DEFAULT_CRON=0 */6 * * *
SOURCE_A_URL=
SOURCE_C_URL=

# SINOE: 32-byte key as hex (64 chars) or base64 — never commit real values.
# Protect DB backups; without this key, ciphertext in user_sinoe_credentials cannot be decrypted.
# Do not log request bodies for /integrations/sinoe/credentials or decrypted passwords.
SINOE_CREDENTIALS_KEY=
# Credenciales planas solo para el runner local de depuración (`pnpm --filter @tracker/worker sinoe:debug`).
# No commitear valores reales. En producción el worker usa credenciales cifradas en DB + SINOE_CREDENTIALS_KEY.
# SINOE_USERNAME=
# SINOE_PASSWORD=
# Carpeta de salida (trace.zip, result.json, step-*.png, events.log). Por defecto /tmp/sinoe-run-<timestamp>
# SINOE_RUN_OUT_DIR=
# Pausa con Playwright Inspector ante error (true/false). Por defecto true en el runner.
# SINOE_PAUSE_ON_ERROR=true
# slowMo en ms al lanzar Chromium en modo debug. Por defecto 150.
# SINOE_SLOWMO_MS=150
# El comando `sinoe:debug` abre el navegador aunque SINOE_HEADLESS=true en .env.
# Para forzar headless solo en esa corrida: SINOE_DEBUG_HEADLESS=true
# Default PJ Peru SINOE login (override if URL changes)
# SINOE_BASE_URL=https://casillas.pj.gob.pe/sinoe/login.xhtml
SINOE_BASE_URL=
# Dispatches one scrape job per user with stored credentials (worker).
SINOE_SCRAPE_CRON=0 */4 * * *
# false / 0 / off: no programar el cron SINOE (sigue existiendo `pnpm sinoe:debug` y el processor si encolas a mano).
# SINOE_SCRAPE_ENABLED=false
# CAPTCHA fallback order: gemini, manual, 2captcha (comma-separated)
SINOE_CAPTCHA_STRATEGY=gemini,manual,2captcha
SINOE_CAPTCHA_GEMINI_MODEL=gemini-2.5-flash
# 2captcha.com API key (image CAPTCHA)
TWOCAPTCHA_API_KEY=
# Search window for inbox / casilla (days)
SINOE_SCRAPE_DATE_RANGE_DAYS=7
# Máx. filas a procesar en tabla Casillas Electrónicas (frmBusqueda:tblLista_data) por corrida
# SINOE_MAX_CASILLA_ROWS=100
# Tiempo máx. (ms) para localizar el tile "Casillas Electrónicas" tras login (default 45000)
# SINOE_CASILLA_NAV_TIMEOUT_MS=45000
SINOE_HEADLESS=true
# Logs extra: conteos por selector de bandeja y URL por fila (worker)
# SINOE_DEBUG=true
# SINOE_LOG_VERBOSE=1
SINOE_CAPTCHA_DEBUG_DIR=/tmp/sinoe-captchas
# Global timeout for one scrape run (ms)
SINOE_SCRAPE_TIMEOUT_MS=180000

# AI providers for SuperDoc editor (at least one required for AI features)
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Asistente (chat en app / WhatsApp): el transcript completo se persiste en BD; al LLM solo se envían los últimos N mensajes (sin contar system) salvo ASSISTANT_HISTORY_WINDOW=0.
# Gemini admite ventanas de entrada muy grandes vía OpenAI-compat; el límite práctico suele ser coste/latencia o el fallback DeepSeek (menor ventana).
# ASSISTANT_MODEL=gemini-2.5-flash
# ASSISTANT_MODEL=gemini-2.5-pro
# Máximo de tokens **generados** en cada respuesta del modelo (no limita cuánto historial entra en el prompt).
# ASSISTANT_MAX_TOKENS=8192
# Pasos máximos tool-call ↔ modelo por turno (default 8, tope 12 en código).
# ASSISTANT_MAX_STEPS=10
# Tiempo máx. por llamada al LLM en ms (peticiones grandes con mucho historial).
# ASSISTANT_LLM_TIMEOUT_MS=120000
# Últimos N mensajes (sin contar system) enviados al LLM por turno. 0 = desactivar ventana (default 40).
# ASSISTANT_HISTORY_WINDOW=40
# Rotar el hilo «WhatsApp» por usuario si pasó N horas sin mensajes (default 4). 0 = no rotar por inactividad.
# ASSISTANT_WHATSAPP_IDLE_HOURS=4
# Días antes de purgar hilos del asistente sin actividad (default 30). 0 = no purgar automáticamente.
# ASSISTANT_THREAD_RETENTION_DAYS=30

# WhatsApp (ADR-030): twilio | dialog360 | meta
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content API (Twilio): listas y botones nativos WhatsApp. Vacío = fallback texto numerado.
# Crear templates y pegar HX...: docs/whatsapp-twilio-interactive-templates.md
TWILIO_CONFIRM_CONTENT_SID=
TWILIO_LIST_CONTENT_SID=
# URL pública donde Twilio alcanza la API (ngrok), sin barra final — misma base que en la consola Twilio para el webhook:
# TWILIO_WEBHOOK_BASE_URL=https://xxxx.ngrok-free.app
# (alias soportado: APP_URL_NGROK)
# Adjuntos de documentos al asistente por WhatsApp (URL firmada que Twilio descarga desde esta API).
WHATSAPP_MEDIA_SECRET=
# WHATSAPP_MEDIA_TTL_SECONDS=600
# WHATSAPP_MEDIA_MAX_BYTES=16777216
DIALOG360_API_KEY=
DIALOG360_WEBHOOK_URL=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_FAILOVER_THRESHOLD=3
WHATSAPP_FAILOVER_RECOVERY_MS=300000
# Worker: cron horario para briefing (filtra tenants por briefingCron en America/Lima)
# Dispara el worker de briefing (revisa hora por tenant en whatsapp_accounts.briefing_cron). Para probar cada minuto: * * * * *
WHATSAPP_BRIEFING_CRON=0 15 42 * *
WHATSAPP_ACTIVITY_CLEANUP_CRON=5 2 * * *
